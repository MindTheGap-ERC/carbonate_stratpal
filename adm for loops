#Height of stratigraphic column at ~2 Myr for scenarioA
v_str_height <- c()
for (str_height in adm){
  test_str_height <- get_height(str_height,1.999,destructive = FALSE)
  v_str_height <- c(v_str_height,test_str_height)
}
print(v_str_height)

#Average hiatus duration from scenarioA
v_hiat_dur <- c()
for(hiat_dur in adm){
  test_hiat_dur <- mean(get_hiat_duration(hiat_dur))
  v_hiat_dur <- c(v_hiat_dur,test_hiat_dur)
}
print(v_hiat_dur)

#Completeness percentage from scenarioA
v_completeness <- c()
for(completeness in adm){
  test_completeness <- get_completeness(completeness)
  v_completeness <- c(v_completeness,test_completeness)
}
print(v_completeness)

#Number of gaps per distance from scenarioA
